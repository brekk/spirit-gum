import Study from "Study"

import Validator from "@/Rule/Validator"



bodyVal = (_, _) => true
lineVal = (_, _, _) => true


Study.report(
  pipe(
    Validator.ofBody,
    Validator.isBody,
  ),
  "ofBody + isBody",
  [#[bodyVal, true]],
)

Study.report(
  pipe(
    Validator.ofLine,
    Validator.isLine,
  ),
  "ofLine + isLine",
  [#[lineVal, true]],
)
