import Fn from "Function"



export type Validator a
  = BodyValidator(a -> String -> Boolean)
  | LineValidator(a -> Integer -> String -> Boolean)

export ofBody = BodyValidator
export ofLine = LineValidator

isBody :: Validator a -> Boolean
export isBody = where {
  BodyValidator(_) =>
    true

  _ =>
    false
}

export isLine = Fn.complement(isBody)


export lineAlwaysValid = LineValidator((_, _, _) => true)
export bodyAlwaysValid = BodyValidator((_, _) => true)
